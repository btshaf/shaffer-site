{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/contact/route.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "bradshaffer.me"
        }
      ],
      "destination": "https://bshaffer.co/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host", 
          "value": "www.bradshaffer.me"
        }
      ],
      "destination": "https://bshaffer.co/$1",
      "permanent": true
    }
  ]
}